# ── Copy to .env and fill in. Never commit .env. ──────────────────────────────

# Postgres (used by both db and server)
POSTGRES_USER=quietfeed
POSTGRES_PASSWORD=change-me-to-a-long-random-password
POSTGRES_DB=quietfeed

# Google Sign-In — OAuth 2.0 Web client ID from Google Cloud Console
# (APIs & Services → Credentials → Create OAuth client ID → Web application).
# Add your site's origin to "Authorized JavaScript origins", e.g. http://localhost:8080
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Anyone whose Google email is in this comma-separated list signs in as an ADMIN.
ADMIN_EMAILS=you@example.com

# Quiet Feed / My-Tube Environment Configuration
# To run this clone side-by-side on EC2, uncomment these:
# COMPOSE_PROJECT_NAME=mytube
# WEB_PORT=8081
# Session signing secret (generate: `openssl rand -hex 32`)
SESSION_SECRET=generate-a-64-char-hex-secret
SESSION_TTL_DAYS=30

# YouTube Data API v3 key (server-side only — never shipped to the browser)
YOUTUBE_API_KEY=AIza...

# Caching / quota controls
CACHE_TTL_MINUTES=60
REFRESH_INTERVAL_MINUTES=30

# Cookies: set COOKIE_SECURE=true once you serve over HTTPS.
COOKIE_SECURE=false

# Only needed if the frontend is on a DIFFERENT origin than the API (else leave blank).
CORS_ORIGIN=

# Host port the web app is published on (http://<host>:WEB_PORT)
WEB_PORT=8080
