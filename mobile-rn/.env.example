# Copy to .env for LOCAL development. Expo inlines EXPO_PUBLIC_* vars at build time.
#
# NOTE: EAS cloud builds do NOT read this file — .env is gitignored, so it is never
# uploaded to the build. The values used by builds live in eas.json under each build
# profile's "env" block. Change them in BOTH places, or the APK will differ from local.

# Base URL of the Quiet Feed backend (no trailing slash).
# If unset, src/config.ts falls back to http://localhost:8080 — which will silently
# fail on a real device.
EXPO_PUBLIC_API_URL=https://quietfeed.devopspractice.live

# The OAuth 2.0 **Web** client ID (the same one the backend verifies against, and the
# same value the web app builds in as VITE_GOOGLE_CLIENT_ID). Not a secret — it is
# embedded in every client. The native sign-in lib needs it so the ID token's audience
# matches what the server expects.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
