# Copy to .env. Expo inlines EXPO_PUBLIC_* vars at build time.

# Base URL of your Quiet Feed backend (no trailing slash).
#  - dev: a reachable HTTPS URL for your backend (e.g. a staging deploy)
#  - prod: your domain, e.g. https://quietfeed.example.com
EXPO_PUBLIC_API_URL=https://your-backend-domain

# The OAuth 2.0 **Web** client ID (same one the backend verifies against).
# The native Google Sign-In lib needs this so the ID token's audience matches the server.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
